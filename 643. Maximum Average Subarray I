class Solution {
    public double findMaxAverage(int[] nums, int k) {
        int length=nums.length;
        int window_sum=0;
        for(int i=0;i<k;i++){
            window_sum+=nums[i];
        }
            int maxsum=window_sum;
            for(int j=k;j<length;j++){
                window_sum+=nums[j];
                window_sum-=nums[j-k];
                maxsum = Math.max(maxsum,window_sum);
            }
            return (double)maxsum/k;
        
    }
   
}
